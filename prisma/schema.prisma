// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/dev.db"
}

model Ortschaft {
  id          Int      @id @default(autoincrement())
  name        String
  gemeinde_id Int
  gemeinde    Gemeinde @relation(fields: [gemeinde_id], references: [id])
  plz         String
  e           Decimal
  n           Decimal
  sprache     String
  favorite    Boolean
}

model Gemeinde {
  id          Int         @id @default(autoincrement())
  name        String
  kanton_id   String
  kanton      Kanton      @relation(fields: [kanton_id], references: [id])
  ortschaften Ortschaft[]
  links       Link[]
}

model Link {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  gemeinde_id Int
  gemeinde    Gemeinde @relation(fields: [gemeinde_id], references: [id])
}

model Kanton {
  id        String     @id
  name_de   String
  name_fr   String
  name_it   String
  gemeinden Gemeinde[]
}

model Firma {
  id          Int     @id @default(autoincrement())
  name        String
  strasse     String
  postfach    String
  plz         String
  ort         String
  mail        String
  webpage     String
  plannerlink String?
  sprache     String
}
